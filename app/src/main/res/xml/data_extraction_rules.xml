<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ variant of backup_rules.xml: same exclusions for cloud backup
     and device-to-device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="models" />
        <exclude domain="file" path="recordings" />
        <exclude domain="file" path="imports" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="models" />
        <exclude domain="file" path="recordings" />
        <exclude domain="file" path="imports" />
    </device-transfer>
</data-extraction-rules>
